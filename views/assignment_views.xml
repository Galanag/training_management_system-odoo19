<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_skill_assignment_tree" model="ir.ui.view">
        <field name="name">skill.assignment.tree</field>
        <field name="model">skill.assignment</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="student_id"/>
                <field name="due_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_skill_assignment_form" model="ir.ui.view">
        <field name="name">skill.assignment.form</field>
        <field name="model">skill.assignment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="student_id"/>
                        <field name="instructor_id"/>
                        <field name="due_date"/>
                        <field name="description"/>
                        <field name="state"/>
                        <field name="grade"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
        <record id="skill_assignment_pivot" model="ir.ui.view">
        <field name="name">assignment.pivot</field>
        <field name="model">skill.assignment</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="state" type="col"/>
                <field name="instructor_id" type="row"/>
                <field name="grade" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_skill_assignment_pivot" model="ir.actions.act_window">
        <field name="name">Assignment Report</field>
        <field name="res_model">skill.assignment</field>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="skill_assignment_pivot"/>
    </record>

    <menuitem id="menu_skill_assignment_pivot" name="Assignment Pivot" parent="menu_skillbridge_root" action="action_skill_assignment_pivot" sequence="51"/>
</odoo>
