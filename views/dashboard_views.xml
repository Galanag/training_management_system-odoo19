<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_skill_dashboard_form" model="ir.ui.view">
        <field name="name">skill.dashboard.form</field>
        <field name="model">skill.dashboard</field>
        <field name="arch" type="xml">
            <form string="Dashboard">
                <sheet>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="card">
                                <div class="card-body text-center">
                                    <h3><field name="total_students"/></h3>
                                    <p>Students</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card">
                                <div class="card-body text-center">
                                    <h3><field name="total_instructors"/></h3>
                                    <p>Instructors</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card">
                                <div class="card-body text-center">
                                    <h3><field name="total_bootcamps"/></h3>
                                    <p>Bootcamps</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card">
                                <div class="card-body text-center">
                                    <h3><field name="ongoing_sessions"/></h3>
                                    <p>Ongoing Sessions</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>
</odoo>