<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_skill_student_tree" model="ir.ui.view">
        <field name="name">skill.student.tree</field>
        <field name="model">skill.student</field>
        <field name="arch" type="xml">
            <list>
                <field name="student_id"/>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_skill_student_form" model="ir.ui.view">
        <field name="name">skill.student.form</field>
        <field name="model">skill.student</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="birth_date"/>
                            <field name="gender"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Batches">
                            <field name="batch_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_skill_student_kanban" model="ir.ui.view">
        <field name="name">skill.student.kanban</field>
        <field name="model">skill.student</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="student_id"/>
                <field name="email"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('res.partner', 'image_128', record.partner_id.raw_value)" alt="Student"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <div class="text-muted o_kanban_record_subtitle"><field name="student_id"/></div>
                                <div><field name="email"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>