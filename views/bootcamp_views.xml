<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_skill_bootcamp_tree" model="ir.ui.view">
        <field name="name">skill.bootcamp.tree</field>
        <field name="model">skill.bootcamp</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="duration_days"/>
            </list>
        </field>
    </record>

    <record id="view_skill_bootcamp_form" model="ir.ui.view">
        <field name="name">skill.bootcamp.form</field>
        <field name="model">skill.bootcamp</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="duration_days"/>
                        <field name="category"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>