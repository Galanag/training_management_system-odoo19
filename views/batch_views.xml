<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_skill_batch_tree" model="ir.ui.view">
        <field name="name">skill.batch.tree</field>
        <field name="model">skill.batch</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="bootcamp_id"/>
                <field name="start_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_skill_batch_form" model="ir.ui.view">
        <field name="name">skill.batch.form</field>
        <field name="model">skill.batch</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="bootcamp_id"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="capacity"/>
                        <field name="instructor_ids" widget="many2many_tags"/>
                        <field name="student_ids" widget="many2many_tags"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>