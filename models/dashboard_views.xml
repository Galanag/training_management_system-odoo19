<record id="view_skill_dashboard_form" model="ir.ui.view">
    <field name="name">skill.dashboard.form</field>
    <field name="model">skill.dashboard</field>
    <field name="arch" type="xml">
        <form string="Dashboard">
            <sheet>
                <div class="row">
                    <div class="col-md-3">
                        <div class="card">
                            <div class="card-body text-center">
                                <h3><field name="total_students"/></h3>
                                <p>Students</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card">
                            <div class="card-body text-center">
                                <h3><field name="total_instructors"/></h3>
                                <p>Instructors</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card">
                            <div class="card-body text-center">
                                <h3><field name="total_bootcamps"/></h3>
                                <p>Bootcamps</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card">
                            <div class="card-body text-center">
                                <h3><field name="ongoing_sessions"/></h3>
                                <p>Ongoing Sessions</p>
                            </div>
                        </div>
                    </div>
                </div>
                <group>
                    <separator string="Recent Sessions"/>
                    <field name="session_ids" widget="calendar" mode="month"/>
                </group>
            </sheet>
        </form>
    </field>
</record>
<record id="action_skill_dashboard" model="ir.actions.act_window">
    <field name="name">Dashboard</field>
    <field name="res_model">skill.dashboard</field>
    <field name="view_mode">form</field>
    <field name="target">main</field>
</record>